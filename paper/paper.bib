@article{griffith_bon_2024,
	title = {{BON} in a {Box}: {An} {Open} and {Collaborative} {Platform} for {Biodiversity} {Monitoring}, {Indicator} {Calculation}, and {Reporting}},
	copyright = {CC BY Attribution 4.0 International},
	shorttitle = {{BON} in a {Box}},
	doi = {10.32942/x2m320},
	url = {https://ecoevorxiv.org/repository/view/7941/},
	abstract = {{\textless}p{\textgreater}The Convention on Biological Diversity’s Kunming-Montreal Global Biodiversity{\textless}br{\textgreater}Framework (GBF) sets ambitious goals to protect and restore biodiversity. It includes a Monitoring Framework that mandates countries to track progress toward these goals using indicators that summarize biodiversity trends. Calculating indicators is challenging for countries due to technical barriers, lack of available data and tools, and capacity bottlenecks. BON in a Box, an open tool for biodiversity modeling and indicator calculation developed by the Group on{\textless}br{\textgreater}Earth Observations Biodiversity Observation Network, is designed to address these challenges. It connects individual analyses into pipelines that convert data into essential biodiversity variables and indicators and can be run locally or on the cloud. These pipelines are community-built, customizable, and can analyze public or user datasets. BON in a Box provides a comprehensive and accessible tool for scientists and policymakers around the world to track progress toward the GBF and make biodiversity management decisions.{\textless}/p{\textgreater}},
	language = {en},
	urldate = {2025-10-15},
	author = {Griffith, Jory and Lord, Jean-Michel and Catchen, Michael D. and Arce-Plata, Maria Isabel and Blanchet, Guillaume and Bohorquez, Manuel Fernandez Galvez and Chandramohan, Matusan and Diaz-Corzo, María Camilla and Gravel, Dominique and Gonzalez, Luis Fernando Urbina and Gutiérrez, César and Helfenstein, Isabelle S. and Hoban, Sean M. and Kass, Jamie M. and Larocque, Guillaume and Laikre, Linda and Leigh, Deborah M. and Leung, Brian and Mastretta-Yanes, Alicia and Millette, Katie and Moreno, Diego and Molina-Berbeo, María Alejandra and Norman, Kari and Rincón-Parra, Víctor J. and Pahls, Simon and Peres-Neto, Pedro R. and Perreira, Kaitlyn and Poisot, Timothée and Pollock, Laura J. and Rey-Velasco, Juan Carlos and Rodríguez, María Helena Olaya and Röösli, Claudia and Rousseu, François and Sánchez-Clavijo, Lina María and Schuman, Meredith Christine and Selmoni, Oliver and Silva, Jessica da and Surasinghe, Thilina and Turak, Eren and Valencia, Erika Suarez and Valentin, Sarah and Wightman, Noah and Zuloaga, Juan and Murcia, María Cecilia Londoño and Gonzalez, Andrew},
	month = oct,
	year = {2024},
	note = {Publisher: EcoEvoRxiv},
}

@article{ramiandrisoa2026,
    doi = {10.1371/journal.pone.0342093},
    author = {Ramiandrisoa, Diamondra AND Bédécarrats, Florent AND Wong, Melvin H. L. AND Razanakoto, Thierry},
    journal = {PLOS ONE},
    publisher = {Public Library of Science},
    title = {Impact of protected areas on deforestation in Madagascar from 2000 to 2023: A pre-analysis plan},
    year = {2026},
    month = {02},
    volume = {21},
    url = {https://doi.org/10.1371/journal.pone.0342093},
    pages = {1-15},
    abstract = {Protected areas are the most prevalent strategy to mitigate biodiversity loss and deforestation, especially in biodiversity hotspots like Madagascar. This pre-analysis plan outlines the data, methods, and identification strategy that will be used to assess the impact on deforestation of terrestrial protected areas created in Madagascar between 2002 and 2022. We will employ coarsened exact matching and difference-in-differences methods to evaluate forest cover loss, leveraging 24 years of high-resolution satellite data. We will incorporate buffer zones to assess spillover and leakage effects. This study addresses limitations of previous ones by combining accurate protected area delimitation and characteristics, a longer temporal coverage, improved characterization of the diverse forest ecosystems, and state-of-the art econometric methods. We will then assess heterogeneity of conservation effects, to better understand the determinants of protected area effectiveness.},
    number = {2},

}